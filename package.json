{
  "name": "tour",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "dotenv": "^17.2.3",
    "gsap": "^3.15.0",
    "pannellum": "^2.5.7",
    "pannellum-react": "^1.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.10.1",
    "react-scripts": "5.0.1",
    "three": "^0.177.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "set HOST= && set \"HOST=0.0.0.0\" && set \"PORT=3000\" && react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "postinstall": "patch-package",
    "start:frontend": "react-scripts start",
    "start:backend": "cd backend && npm run prisma:generate && npm start",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\" --names \"BACKEND,FRONTEND\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-keywords": "^5.1.0",
    "concurrently": "^9.2.1",
    "patch-package": "^8.0.1",
    "prisma": "^6.19.3"
  }
}
